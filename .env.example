# Copia in `.env` (gitignorato) e riempi. NON committare `.env`.

# Personal Access Token Supabase dell'account di QUESTO progetto.
# Dashboard → Account → Access Tokens. Sovrascrive il login globale della CLI,
# così gli altri progetti/account restano intatti (niente `supabase login`).
SUPABASE_ACCESS_TOKEN=

# Ref del progetto Supabase (Dashboard → Project Settings → General → Reference ID).
# Usato da `supabase link --project-ref $SUPABASE_PROJECT_REF`.
SUPABASE_PROJECT_REF=

# Database password (quella forte copiata alla creazione del progetto).
# Serve per `supabase db push`. Resettabile in Project Settings → Database.
SUPABASE_DB_PASSWORD=

# GitHub Personal Access Token (scope `repo`) per pubblicare le Release via
# `npm run release` (electron-builder --publish). Usato SOLO dalla build machine,
# NON finisce nell'app. Crea su github.com/settings/tokens.
GH_TOKEN=
